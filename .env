# Configuration sécurisée pour IT Access
# Générez un nouveau secret avec : openssl rand -base64 64
JWT_SECRET=VOTRE_SECRET_JWT_SECURISE_ICI_MINIMUM_256_BITS

# Configuration PostgreSQL
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/itaccessdb
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=votre_mot_de_passe_postgres

# Configuration Email (optionnel)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=votre_email@gmail.com
SMTP_PASSWORD=votre_app_password_gmail
MAIL_FROM=noreply@itaccess.local

# Configuration serveur
SERVER_PORT=8000

# Configuration CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

# Configuration Frontend
FRONTEND_URL=http://localhost:3000

# Configuration Upload
UPLOAD_DIR=./uploads/apk
MAX_FILE_SIZE=150MB

# Logging
LOG_LEVEL=INFO
